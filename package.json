{
  "name": "emotion-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outdir=dist/server --packages=external",
    "start": "node dist/server/index.js",
    "check": "tsc --noEmit && npm run check:triage",
    "check:triage": "tsx scripts/triage-regression.ts",
    "backfill:triage": "tsx scripts/backfill-triage.ts",
    "backup": "node scripts/backup-db.mjs",
    "restore": "node scripts/restore-db.mjs",
    "bootstrap:support": "node scripts/bootstrap-support.mjs",
    "release:bundle": "npm run build && node scripts/create-release-bundle.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.2",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  },
  "engines": {
    "node": ">=22"
  }
}
